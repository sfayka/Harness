{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness.dev/schemas/task_envelope.schema.json",
  "title": "TaskEnvelope",
  "description": "Canonical structured work contract for the Harness control plane.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "description",
    "origin",
    "status",
    "timestamps",
    "objective",
    "constraints",
    "acceptance_criteria",
    "parent_task_id",
    "child_task_ids",
    "dependencies",
    "assigned_executor",
    "required_capabilities",
    "priority",
    "artifacts",
    "observability"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for this task envelope."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Short human-readable task label."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Detailed task description."
    },
    "origin": {
      "$ref": "#/$defs/origin"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "timestamps": {
      "$ref": "#/$defs/timestamps"
    },
    "status_history": {
      "type": "array",
      "description": "Ordered audit trail of non-initial status changes.",
      "items": {
        "$ref": "#/$defs/statusHistoryEntry"
      },
      "default": []
    },
    "objective": {
      "$ref": "#/$defs/objective"
    },
    "constraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/constraint"
      },
      "default": []
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/acceptanceCriterion"
      },
      "default": []
    },
    "parent_task_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "Parent task identifier if this task was produced by decomposition."
    },
    "child_task_ids": {
      "type": "array",
      "description": "Identifiers of direct child tasks.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    },
    "dependencies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependency"
      },
      "default": []
    },
    "assigned_executor": {
      "description": "Current executor routing decision if one exists.",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/assignedExecutor"
        }
      ]
    },
    "required_capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    },
    "priority": {
      "$ref": "#/$defs/priority"
    },
    "artifacts": {
      "$ref": "#/$defs/artifacts"
    },
    "clarification": {
      "$ref": "#/$defs/clarification"
    },
    "observability": {
      "$ref": "#/$defs/observability"
    },
    "extensions": {
      "type": "object",
      "description": "Explicit non-canonical extension surface for future modules.",
      "default": {},
      "additionalProperties": true
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "intake_ready",
        "planned",
        "dispatch_ready",
        "assigned",
        "executing",
        "blocked",
        "completed",
        "failed",
        "canceled"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "normal",
        "low",
        "backlog"
      ]
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_system",
        "source_type",
        "source_id"
      ],
      "properties": {
        "source_system": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "enum": [
            "ingress_request",
            "task_decomposition",
            "retry",
            "manual",
            "synchronization",
            "system_generated"
          ]
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "ingress_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "ingress_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "requested_by": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at",
        "updated_at",
        "completed_at"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "statusHistoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_status",
        "to_status",
        "changed_at"
      ],
      "properties": {
        "from_status": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/status"
            }
          ]
        },
        "to_status": {
          "$ref": "#/$defs/status"
        },
        "changed_at": {
          "type": "string",
          "format": "date-time"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "changed_by": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "deliverable_type",
        "success_signal"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "deliverable_type": {
          "type": "string",
          "minLength": 1
        },
        "success_signal": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "description",
        "required"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "acceptanceCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "required"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "dependency_type",
        "required_status"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "dependency_type": {
          "type": "string",
          "enum": [
            "blocks",
            "related"
          ]
        },
        "required_status": {
          "type": "string",
          "enum": [
            "planned",
            "dispatch_ready",
            "assigned",
            "executing",
            "completed"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "assignedExecutor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executor_type",
        "executor_id"
      ],
      "properties": {
        "executor_type": {
          "type": "string",
          "minLength": 1
        },
        "executor_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "assignment_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "items",
        "completion_evidence"
      ],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRecord"
          },
          "default": []
        },
        "completion_evidence": {
          "$ref": "#/$defs/completionEvidence"
        }
      }
    },
    "clarification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "required_inputs",
        "questions",
        "responses"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_required",
            "required",
            "requested",
            "answered",
            "resolved"
          ]
        },
        "blocking_reason": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "missing_information",
            "ambiguous_information",
            "waiting_on_human_input",
            "waiting_on_system_input",
            null
          ]
        },
        "resume_target_status": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "intake_ready",
            "planned",
            "dispatch_ready",
            "assigned",
            "executing",
            null
          ]
        },
        "required_inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/clarificationInput"
          },
          "default": []
        },
        "questions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/clarificationQuestion"
          },
          "default": []
        },
        "responses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/clarificationResponse"
          },
          "default": []
        },
        "requested_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "resolved_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "requested_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "resolution_summary": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "requested"
              }
            }
          },
          "then": {
            "properties": {
              "requested_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "resolved"
              }
            }
          },
          "then": {
            "properties": {
              "resolved_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      ]
    },
    "clarificationInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "description",
        "required",
        "need_type",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "need_type": {
          "type": "string",
          "enum": [
            "missing",
            "ambiguous",
            "incomplete",
            "confirmation"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "provided",
            "waived"
          ]
        },
        "value_summary": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "clarificationQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "prompt",
        "status",
        "asked_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "input_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "answered",
            "canceled"
          ]
        },
        "asked_at": {
          "type": "string",
          "format": "date-time"
        },
        "asked_to": {
          "type": [
            "string",
            "null"
          ]
        },
        "channel": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "clarificationResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "content",
        "received_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "question_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "input_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "responder": {
          "type": [
            "string",
            "null"
          ]
        },
        "received_at": {
          "type": "string",
          "format": "date-time"
        },
        "content": {
          "type": "string",
          "minLength": 1
        },
        "source_system": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "artifactRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "provenance",
        "verification_status",
        "repository",
        "branch",
        "changed_files",
        "external_refs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "pull_request",
            "commit",
            "branch",
            "changed_file",
            "log",
            "output",
            "review_note",
            "progress_artifact",
            "plan_artifact",
            "handoff_artifact"
          ]
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "location": {
          "type": [
            "string",
            "null"
          ]
        },
        "content_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "external_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "commit_sha": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-fA-F0-9]{7,40}$"
        },
        "pull_request_number": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "review_state": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "approved",
            "changes_requested",
            "commented",
            "dismissed",
            null
          ]
        },
        "provenance": {
          "$ref": "#/$defs/artifactProvenance"
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "unverified",
            "verified",
            "rejected",
            "informational"
          ]
        },
        "repository": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/repositoryIdentity"
            }
          ]
        },
        "branch": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/branchIdentity"
            }
          ]
        },
        "changed_files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/changedFile"
          },
          "default": []
        },
        "external_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/externalReference"
          },
          "default": []
        },
        "captured_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "metadata": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "pull_request"
              }
            }
          },
          "then": {
            "required": [
              "pull_request_number"
            ],
            "properties": {
              "repository": {
                "$ref": "#/$defs/repositoryIdentity"
              },
              "branch": {
                "$ref": "#/$defs/branchIdentity"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "commit"
              }
            }
          },
          "then": {
            "required": [
              "commit_sha"
            ],
            "properties": {
              "repository": {
                "$ref": "#/$defs/repositoryIdentity"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "branch"
              }
            }
          },
          "then": {
            "properties": {
              "repository": {
                "$ref": "#/$defs/repositoryIdentity"
              },
              "branch": {
                "$ref": "#/$defs/branchIdentity"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "changed_file"
              }
            }
          },
          "then": {
            "properties": {
              "repository": {
                "$ref": "#/$defs/repositoryIdentity"
              },
              "branch": {
                "$ref": "#/$defs/branchIdentity"
              },
              "changed_files": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "artifactProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_system",
        "source_type",
        "source_id"
      ],
      "properties": {
        "source_system": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "minLength": 1
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "captured_by": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "repositoryIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host",
        "owner",
        "name"
      ],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "external_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "branchIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "base_branch"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "base_branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "head_commit_sha": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-fA-F0-9]{7,40}$"
        }
      }
    },
    "changedFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "change_type"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "change_type": {
          "type": "string",
          "enum": [
            "added",
            "modified",
            "deleted",
            "renamed",
            "copied",
            "unknown"
          ]
        },
        "previous_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "additions": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "deletions": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "externalReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "id"
      ],
      "properties": {
        "system": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        }
      }
    },
    "completionEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "status",
        "required_artifact_types",
        "validated_artifact_ids",
        "validation_method",
        "validated_at",
        "validator"
      ],
      "properties": {
        "policy": {
          "type": "string",
          "enum": [
            "deferred",
            "required",
            "advisory_only",
            "not_applicable"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "deferred",
            "pending",
            "satisfied",
            "insufficient",
            "not_applicable"
          ]
        },
        "required_artifact_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "pull_request",
              "commit",
              "branch",
              "changed_file",
              "log",
              "output",
              "review_note"
            ]
          },
          "uniqueItems": true,
          "default": []
        },
        "validated_artifact_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": []
        },
        "validation_method": {
          "type": "string",
          "enum": [
            "deferred",
            "artifact_presence",
            "external_reconciliation",
            "manual_review",
            "mixed",
            "none"
          ]
        },
        "validated_at": {
          "type": [
